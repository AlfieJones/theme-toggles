---
import ToggleDetailLayout from "../../layouts/ToggleDetailLayout.astro";
import { TOGGLE_SLUGS } from "../../components/Toggle";
import { getStars } from "../../lib/github";
import { readFileSync } from "fs";
import { resolve } from "path";

export const prerender = true;

export function getStaticPaths() {
  return TOGGLE_SLUGS.map((slug) => ({
    params: { slug },
  }));
}

const { slug } = Astro.params as { slug: string };
const isValidSlug = TOGGLE_SLUGS.includes(
  slug as (typeof TOGGLE_SLUGS)[number],
);
if (!isValidSlug) return Astro.rewrite("/404");

const componentName = slug
  .split("-")
  .map((s: string) => s[0].toUpperCase() + s.slice(1))
  .join("");

const displayName = slug
  .split("-")
  .map((s: string) => s[0].toUpperCase() + s.slice(1))
  .join(" ");

const description = `${displayName} is an animated theme toggle component for React, Svelte, and Vue. Install it with shadcn/ui, npm, or copy the source.`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareSourceCode",
  name: `${displayName} theme toggle`,
  description,
  codeRepository: "https://github.com/alfiejones/theme-toggles",
  programmingLanguage: ["TypeScript", "TSX", "Svelte", "Vue"],
  runtimePlatform: ["React", "Svelte", "Vue"],
  url: `https://toggles.dev/toggles/${slug}`,
  license: "https://opensource.org/license/mit",
};

const stars = await getStars();
const root = resolve(process.cwd(), "..");

let reactSource = "";
let svelteSource = "";
let vueSource = "";
try {
  reactSource = readFileSync(
    resolve(root, `packages/react/src/${componentName}.tsx`),
    "utf-8",
  );
} catch {}
try {
  svelteSource = readFileSync(
    resolve(root, `packages/svelte/src/${componentName}.svelte`),
    "utf-8",
  );
} catch {}
try {
  vueSource = readFileSync(
    resolve(root, `packages/vue/src/${componentName}.vue`),
    "utf-8",
  );
} catch {}
---

<ToggleDetailLayout
  slug={slug as (typeof TOGGLE_SLUGS)[number]}
  displayName={displayName}
  description={description}
  jsonLd={jsonLd}
  stars={stars}
  reactSource={reactSource}
  svelteSource={svelteSource}
  vueSource={vueSource}
/>
