---
export const prerender = true;
import Layout from "../layouts/Layout.astro";
import { GifCarousel } from "../components/GifCarousel";
---

<Layout>
  <div class="flex flex-col grow min-h-screen">
    <div class="border-b border-neutral-300 dark:border-neutral-700">
      <div
        class="relative container mx-auto border-x border-neutral-300 dark:border-neutral-700 px-6 py-4 flex items-center gap-2 text-sm text-neutral-500 dark:text-neutral-400"
      >
        <a
          href="/"
          class="inline-flex items-center gap-1.5 text-neutral-700 dark:text-neutral-200 hover:text-black dark:hover:text-white transition-colors font-medium"
        >
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="m15 18-6-6 6-6" />
          </svg>
          Back
        </a>
        <span class="text-neutral-300 dark:text-neutral-700">|</span>
        <span>Assembly Line</span>
      </div>
    </div>

    <main class="flex flex-col flex-1 items-center justify-center relative">
      <div
        class="relative container mx-auto border-x border-neutral-300 dark:border-neutral-700 flex flex-col flex-1 items-center justify-center"
      >
        <GifCarousel client:load />
      </div>
    </main>
  </div>
</Layout>
