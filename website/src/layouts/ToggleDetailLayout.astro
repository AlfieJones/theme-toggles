---
import Layout from "./Layout.astro";
import BoltCorners from "../components/BoltCorners.astro";
import { BackLink } from "../components/BackLink";
import { ThemeToggle } from "../components/ThemeToggle";
import { TogglePreview } from "../components/TogglePreview";
import InstallSection from "../components/InstallSection.astro";
import type { TOGGLE_SLUGS } from "../components/Toggle";

interface Props {
  slug: (typeof TOGGLE_SLUGS)[number];
  displayName: string;
  stars: number | null;
  reactSource: string;
  svelteSource: string;
  vueSource: string;
}

const { slug, displayName, stars, reactSource, svelteSource, vueSource } =
  Astro.props;
---

<Layout>
  <div class="flex flex-col grow">
    <div class="border-b border-neutral-300 dark:border-neutral-700">
      <div
        class="relative container mx-auto border-x border-neutral-300 dark:border-neutral-700 px-4 sm:px-8 py-4 flex items-center justify-between gap-3 min-w-0"
      >
        <span
          class="bolt absolute bottom-0 left-0 -translate-x-1/2 translate-y-1/2"
        ></span>
        <span
          class="bolt absolute bottom-0 right-0 translate-x-1/2 translate-y-1/2"
        ></span>
        <BackLink
          slug={slug}
          className="text-sm text-neutral-500 hover:text-neutral-900 dark:hover:text-neutral-50 transition-colors cursor-pointer shrink-0"
          client:load
        />
        <div class="flex items-center gap-2 sm:gap-3 min-w-0">
          <span
            class="hidden sm:inline text-sm text-neutral-500 dark:text-neutral-400 truncate"
          >
            {displayName}
          </span>
          <a
            href="https://github.com/alfiejones/theme-toggles"
            target="_blank"
            rel="noopener noreferrer"
            transition:name="github-link"
            class="flex items-center gap-1.5 border border-neutral-300 dark:border-neutral-700 bg-neutral-100 dark:bg-neutral-800 hover:bg-neutral-200 dark:hover:bg-neutral-700 transition-colors text-xs text-neutral-600 dark:text-neutral-400 px-2.5 py-1 cursor-pointer no-underline"
          >
            <svg
              height="14"
              width="14"
              viewBox="0 0 16 16"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"
              ></path>
            </svg>
            {
              stars !== null ? (
                <>
                  {stars.toLocaleString()}
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="1.5"
                    stroke="currentColor"
                    width="14"
                    height="14"
                    aria-hidden="true"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z"
                    />
                  </svg>
                </>
              ) : (
                "GitHub"
              )
            }
          </a>
          <span class="inline-flex items-center" transition:name="theme-toggle">
            <ThemeToggle client:load className="text-3xl cursor-pointer" />
          </span>
        </div>
      </div>
    </div>

    <main class="flex flex-col flex-1">
      <div class="border-b border-neutral-300 dark:border-neutral-700">
        <div
          class="relative container mx-auto border-x border-neutral-300 dark:border-neutral-700"
        >
          <BoltCorners />
          <div class="grid lg:grid-cols-2 overflow-hidden">
            <div class="lg:sticky lg:top-0 lg:self-start">
              <div
                transition:name={`toggle-card-${slug}`}
                class="relative border-b lg:border-b-0 lg:border-r border-neutral-300 dark:border-neutral-700 bg-neutral-50 dark:bg-neutral-900 h-116 overflow-hidden"
              >
                <span class="bolt top-4 left-4"></span>
                <span class="bolt top-4 right-4"></span>
                <span class="bolt bottom-4 left-4"></span>
                <span class="bolt bottom-4 right-4"></span>
                <TogglePreview slug={slug} client:only="react" />
              </div>
            </div>
            <div
              class="bg-neutral-100 dark:bg-neutral-900 min-w-0 overflow-hidden"
            >
              <InstallSection
                slug={slug}
                reactSource={reactSource}
                svelteSource={svelteSource}
                vueSource={vueSource}
              />
            </div>
          </div>
        </div>
      </div>
      <div
        class="relative flex-1 container mx-auto border-x border-neutral-300 dark:border-neutral-700"
      >
        <span
          class="bolt z-10 absolute top-0 left-0 -translate-x-1/2 -translate-y-1/2"
        ></span>
        <span
          class="bolt absolute top-0 right-0 translate-x-1/2 -translate-y-1/2"
        ></span>
      </div>
    </main>
  </div>
</Layout>

<style>
  .bolt {
    position: absolute;
    width: 0.625rem;
    height: 0.625rem;
    border: 1px solid var(--color-neutral-300);
    background: var(--color-neutral-200);
  }

  :global(.dark) .bolt {
    border-color: var(--color-neutral-700);
    background: var(--color-neutral-800);
  }
</style>
