---
import { Code } from "astro:components";

interface Props {
  slug: string;
  reactSource: string;
  svelteSource: string;
}

const { slug, reactSource, svelteSource } = Astro.props;

const componentName = slug
  .split("-")
  .map((s: string) => s[0].toUpperCase() + s.slice(1))
  .join("");

const shadcnInstall = `npx shadcn@latest add https://toggles.dev/r/${slug}`;
const shadcnUsage = `import { ${componentName} } from "@/components/ui/${slug}";\n\nexport default function App() {\n  return <${componentName} />;\n}`;
const reactInstall = `npm install @theme-toggles/react`;
const svelteInstall = `npm install @theme-toggles/svelte`;
---

<div data-install class="flex flex-col h-full bg-white dark:bg-neutral-900">
  <!-- Framework tabs -->
  <div class="flex border-b border-neutral-300 dark:border-neutral-700">
    <button
      data-fw-btn="react"
      data-active
      class="px-6 py-3 text-sm cursor-pointer transition-colors text-neutral-500 hover:bg-neutral-100 dark:hover:bg-neutral-800 data-[active]:bg-neutral-100 data-[active]:text-neutral-900 dark:data-[active]:bg-neutral-800 dark:data-[active]:text-neutral-50 border-r border-neutral-300 dark:border-neutral-700"
      >react</button
    >
    <button
      data-fw-btn="svelte"
      class="px-6 py-3 text-sm cursor-pointer transition-colors text-neutral-500 hover:bg-neutral-100 dark:hover:bg-neutral-800 data-[active]:bg-neutral-100 data-[active]:text-neutral-900 dark:data-[active]:bg-neutral-800 dark:data-[active]:text-neutral-50 border-r border-neutral-300 dark:border-neutral-700"
      >svelte</button
    >
  </div>

  <!-- Method tabs -->
  <div
    data-method-row
    class="flex border-b border-neutral-300 dark:border-neutral-700"
  >
    <button
      data-method-btn="shadcn"
      data-active
      class="px-6 py-3 text-sm cursor-pointer transition-colors text-neutral-500 hover:bg-neutral-100 dark:hover:bg-neutral-800 data-[active]:bg-neutral-100 data-[active]:text-neutral-900 dark:data-[active]:bg-neutral-800 dark:data-[active]:text-neutral-50 border-r border-neutral-300 dark:border-neutral-700"
      >shadcn/ui</button
    >
    <button
      data-method-btn="manual"
      class="px-6 py-3 text-sm cursor-pointer transition-colors text-neutral-500 hover:bg-neutral-100 dark:hover:bg-neutral-800 data-[active]:bg-neutral-100 data-[active]:text-neutral-900 dark:data-[active]:bg-neutral-800 dark:data-[active]:text-neutral-50 border-r border-neutral-300 dark:border-neutral-700"
      >Manual</button
    >
  </div>

  <!-- react + shadcn -->
  <div data-panel="react-shadcn">
    <div
      class="border-b border-neutral-300 dark:border-neutral-700 last:border-b-0"
    >
      <div
        class="px-6 py-3 flex items-center gap-3 border-b border-neutral-300 dark:border-neutral-700 bg-neutral-100 dark:bg-neutral-800"
      >
        <span
          class="border border-neutral-300 dark:border-neutral-600 w-5 h-5 flex items-center justify-center text-xs text-neutral-500 dark:text-neutral-400 shrink-0"
          >1</span
        >
        <span class="text-xs text-neutral-500 dark:text-neutral-400"
          >Run the shadcn CLI</span
        >
      </div>
      <div
        class="relative min-w-0 overflow-hidden [&_pre]:overflow-auto [&_pre]:max-h-72 [&_pre]:p-6 [&_pre]:text-xs [&_pre]:leading-relaxed"
      >
        <button
          data-copy-btn
          class="absolute top-3 right-3 z-10 text-xs px-3 py-1 border border-neutral-300 dark:border-neutral-600 text-neutral-500 dark:text-neutral-400 cursor-pointer transition-colors bg-transparent hover:bg-neutral-200 dark:hover:bg-neutral-700"
          >Copy</button
        >
        <Code
          code={shadcnInstall}
          lang="bash"
          themes={{ light: "github-light", dark: "github-dark" }}
        />
      </div>
    </div>
    <div
      class="border-b border-neutral-300 dark:border-neutral-700 last:border-b-0"
    >
      <div
        class="px-6 py-3 flex items-center gap-3 border-b border-neutral-300 dark:border-neutral-700 bg-neutral-100 dark:bg-neutral-800"
      >
        <span
          class="border border-neutral-300 dark:border-neutral-600 w-5 h-5 flex items-center justify-center text-xs text-neutral-500 dark:text-neutral-400 shrink-0"
          >2</span
        >
        <span class="text-xs text-neutral-500 dark:text-neutral-400"
          >Import and use</span
        >
      </div>
      <div
        class="relative min-w-0 overflow-hidden [&_pre]:overflow-auto [&_pre]:max-h-72 [&_pre]:p-6 [&_pre]:text-xs [&_pre]:leading-relaxed"
      >
        <button
          data-copy-btn
          class="absolute top-3 right-3 z-10 text-xs px-3 py-1 border border-neutral-300 dark:border-neutral-600 text-neutral-500 dark:text-neutral-400 cursor-pointer transition-colors bg-transparent hover:bg-neutral-200 dark:hover:bg-neutral-700"
          >Copy</button
        >
        <Code
          code={shadcnUsage}
          lang="tsx"
          themes={{ light: "github-light", dark: "github-dark" }}
        />
      </div>
    </div>
  </div>

  <!-- react + manual -->
  <div data-panel="react-manual" hidden>
    <div
      class="border-b border-neutral-300 dark:border-neutral-700 last:border-b-0"
    >
      <div
        class="px-6 py-3 flex items-center gap-3 border-b border-neutral-300 dark:border-neutral-700 bg-neutral-100 dark:bg-neutral-800"
      >
        <span
          class="border border-neutral-300 dark:border-neutral-600 w-5 h-5 flex items-center justify-center text-xs text-neutral-500 dark:text-neutral-400 shrink-0"
          >1</span
        >
        <span class="text-xs text-neutral-500 dark:text-neutral-400"
          >Install dependencies</span
        >
      </div>
      <div
        class="relative min-w-0 overflow-hidden [&_pre]:overflow-auto [&_pre]:max-h-72 [&_pre]:p-6 [&_pre]:text-xs [&_pre]:leading-relaxed"
      >
        <button
          data-copy-btn
          class="absolute top-3 right-3 z-10 text-xs px-3 py-1 border border-neutral-300 dark:border-neutral-600 text-neutral-500 dark:text-neutral-400 cursor-pointer transition-colors bg-transparent hover:bg-neutral-200 dark:hover:bg-neutral-700"
          >Copy</button
        >
        <Code
          code={reactInstall}
          lang="bash"
          themes={{ light: "github-light", dark: "github-dark" }}
        />
      </div>
    </div>
    <div
      class="border-b border-neutral-300 dark:border-neutral-700 last:border-b-0"
    >
      <div
        class="px-6 py-3 flex items-center gap-3 border-b border-neutral-300 dark:border-neutral-700 bg-neutral-100 dark:bg-neutral-800"
      >
        <span
          class="border border-neutral-300 dark:border-neutral-600 w-5 h-5 flex items-center justify-center text-xs text-neutral-500 dark:text-neutral-400 shrink-0"
          >2</span
        >
        <span class="text-xs text-neutral-500 dark:text-neutral-400"
          >Copy the component</span
        >
      </div>
      <div
        class="relative min-w-0 overflow-hidden [&_pre]:overflow-auto [&_pre]:max-h-72 [&_pre]:p-6 [&_pre]:text-xs [&_pre]:leading-relaxed"
      >
        <button
          data-copy-btn
          class="absolute top-3 right-3 z-10 text-xs px-3 py-1 border border-neutral-300 dark:border-neutral-600 text-neutral-500 dark:text-neutral-400 cursor-pointer transition-colors bg-transparent hover:bg-neutral-200 dark:hover:bg-neutral-700"
          >Copy</button
        >
        <Code
          code={reactSource}
          lang="tsx"
          themes={{ light: "github-light", dark: "github-dark" }}
        />
      </div>
    </div>
  </div>

  <!-- svelte -->
  <div data-panel="svelte" hidden>
    <div
      class="border-b border-neutral-300 dark:border-neutral-700 last:border-b-0"
    >
      <div
        class="px-6 py-3 flex items-center gap-3 border-b border-neutral-300 dark:border-neutral-700 bg-neutral-100 dark:bg-neutral-800"
      >
        <span
          class="border border-neutral-300 dark:border-neutral-600 w-5 h-5 flex items-center justify-center text-xs text-neutral-500 dark:text-neutral-400 shrink-0"
          >1</span
        >
        <span class="text-xs text-neutral-500 dark:text-neutral-400"
          >Install dependencies</span
        >
      </div>
      <div
        class="relative min-w-0 overflow-hidden [&_pre]:overflow-auto [&_pre]:max-h-72 [&_pre]:p-6 [&_pre]:text-xs [&_pre]:leading-relaxed"
      >
        <button
          data-copy-btn
          class="absolute top-3 right-3 z-10 text-xs px-3 py-1 border border-neutral-300 dark:border-neutral-600 text-neutral-500 dark:text-neutral-400 cursor-pointer transition-colors bg-transparent hover:bg-neutral-200 dark:hover:bg-neutral-700"
          >Copy</button
        >
        <Code
          code={svelteInstall}
          lang="bash"
          themes={{ light: "github-light", dark: "github-dark" }}
        />
      </div>
    </div>
    <div
      class="border-b border-neutral-300 dark:border-neutral-700 last:border-b-0"
    >
      <div
        class="px-6 py-3 flex items-center gap-3 border-b border-neutral-300 dark:border-neutral-700 bg-neutral-100 dark:bg-neutral-800"
      >
        <span
          class="border border-neutral-300 dark:border-neutral-600 w-5 h-5 flex items-center justify-center text-xs text-neutral-500 dark:text-neutral-400 shrink-0"
          >2</span
        >
        <span class="text-xs text-neutral-500 dark:text-neutral-400"
          >Copy the component</span
        >
      </div>
      <div
        class="relative min-w-0 overflow-hidden [&_pre]:overflow-auto [&_pre]:max-h-72 [&_pre]:p-6 [&_pre]:text-xs [&_pre]:leading-relaxed"
      >
        <button
          data-copy-btn
          class="absolute top-3 right-3 z-10 text-xs px-3 py-1 border border-neutral-300 dark:border-neutral-600 text-neutral-500 dark:text-neutral-400 cursor-pointer transition-colors bg-transparent hover:bg-neutral-200 dark:hover:bg-neutral-700"
          >Copy</button
        >
        <Code
          code={svelteSource}
          lang="svelte"
          themes={{ light: "github-light", dark: "github-dark" }}
        />
      </div>
    </div>
  </div>
</div>

<style is:global>
  .astro-code {
    background-color: var(--color-neutral-100) !important;
  }
  .dark .astro-code {
    background-color: var(--color-neutral-900) !important;
    color: var(--shiki-dark) !important;
  }
  .dark .astro-code span {
    color: var(--shiki-dark) !important;
  }
</style>

<script>
  function initInstallSection(section: Element) {
    let fw = "react";
    let method = "shadcn";

    const fwBtns = section.querySelectorAll<HTMLButtonElement>("[data-fw-btn]");
    const methodBtns =
      section.querySelectorAll<HTMLButtonElement>("[data-method-btn]");
    const methodRow = section.querySelector<HTMLElement>("[data-method-row]");
    const panels = section.querySelectorAll<HTMLElement>("[data-panel]");

    function showPanel() {
      const active = fw === "svelte" ? "svelte" : `${fw}-${method}`;
      panels.forEach((p) => (p.hidden = p.dataset.panel !== active));
      if (methodRow) methodRow.hidden = fw !== "react";
    }

    fwBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        fw = btn.dataset.fwBtn!;
        fwBtns.forEach((b) => delete b.dataset.active);
        btn.dataset.active = "";
        showPanel();
      });
    });

    methodBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        method = btn.dataset.methodBtn!;
        methodBtns.forEach((b) => delete b.dataset.active);
        btn.dataset.active = "";
        showPanel();
      });
    });

    section
      .querySelectorAll<HTMLButtonElement>("[data-copy-btn]")
      .forEach((btn) => {
        btn.addEventListener("click", () => {
          const pre = btn.nextElementSibling as HTMLPreElement;
          if (pre) {
            navigator.clipboard.writeText(pre.textContent ?? "");
            btn.textContent = "Copied!";
            setTimeout(() => (btn.textContent = "Copy"), 2000);
          }
        });
      });
  }

  function init() {
    document.querySelectorAll("[data-install]").forEach(initInstallSection);
  }

  init();
  document.addEventListener("astro:page-load", init);
</script>
