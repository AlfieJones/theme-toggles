---
import { Code } from "astro:components";

interface Props {
  slug: string;
  reactSource: string;
  svelteSource: string;
  vueSource: string;
}

const { slug, reactSource, svelteSource, vueSource } = Astro.props;

const componentName = slug
  .split("-")
  .map((s: string) => s[0].toUpperCase() + s.slice(1))
  .join("");

const shadcnInstall = `npx shadcn@latest add https://toggles.dev/r/${slug}`;
const shadcnUsage = `import { ${componentName} } from "@/components/ui/${slug}";\n\nexport default function App() {\n  return <${componentName} />;\n}`;
const npmUsage = `import { ${componentName} } from "@theme-toggles/react";\nimport "@theme-toggles/react/styles/${slug}.css";\n\nexport default function App() {\n  return <${componentName} />;\n}`;
const svelteNpmUsage = `<script>\n  import { ${componentName} } from "@theme-toggles/svelte";\n  import "@theme-toggles/svelte/styles/${slug}.css";\n</script>\n\n<${componentName} />`;
const vueNpmUsage = `<script setup lang="ts">\nimport { ${componentName} } from "@theme-toggles/vue";\nimport "@theme-toggles/vue/styles/${slug}.css";\n</script>\n\n<template>\n  <${componentName} />\n</template>`;

const pkgManagers = [
  { id: "npm", install: (pkg: string) => `npm install ${pkg}` },
  { id: "pnpm", install: (pkg: string) => `pnpm add ${pkg}` },
  { id: "yarn", install: (pkg: string) => `yarn add ${pkg}` },
  { id: "bun", install: (pkg: string) => `bun add ${pkg}` },
];
---

<div data-install data-toggle-slug={slug} class="flex flex-col h-full">
  <!-- Framework tabs -->
  <div class="flex border-b border-neutral-300 dark:border-neutral-700">
    <button
      data-fw-btn="react"
      data-active
      class="px-6 py-3 text-sm cursor-pointer transition-colors text-neutral-500 hover:bg-neutral-100 dark:hover:bg-neutral-800 data-[active]:bg-neutral-950 data-[active]:text-neutral-50 dark:data-[active]:bg-neutral-800 dark:data-[active]:text-neutral-50 border-r border-neutral-300 dark:border-neutral-700"
      >react</button
    >
    <button
      data-fw-btn="svelte"
      class="px-6 py-3 text-sm cursor-pointer transition-colors text-neutral-500 hover:bg-neutral-100 dark:hover:bg-neutral-800 data-[active]:bg-neutral-950 data-[active]:text-neutral-50 dark:data-[active]:bg-neutral-800 dark:data-[active]:text-neutral-50 border-r border-neutral-300 dark:border-neutral-700"
      >svelte</button
    >
    <button
      data-fw-btn="vue"
      class="px-6 py-3 text-sm cursor-pointer transition-colors text-neutral-500 hover:bg-neutral-100 dark:hover:bg-neutral-800 data-[active]:bg-neutral-950 data-[active]:text-neutral-50 dark:data-[active]:bg-neutral-800 dark:data-[active]:text-neutral-50 border-r border-neutral-300 dark:border-neutral-700"
      >vue</button
    >
  </div>

  <!-- React method tabs -->
  <div
