---
import { Code } from "astro:components";

interface Props {
  slug: string;
  reactSource: string;
  svelteSource: string;
}

const { slug, reactSource, svelteSource } = Astro.props;

const componentName = slug
  .split("-")
  .map((s: string) => s[0].toUpperCase() + s.slice(1))
  .join("");

const shadcnInstall = `npx shadcn@latest add https://toggles.dev/r/${slug}`;
const shadcnUsage = `import { ${componentName} } from "@/components/ui/${slug}";\n\nexport default function App() {\n  return <${componentName} />;\n}`;
const reactInstall = `npm install @theme-toggles/react`;
const svelteInstall = `npm install @theme-toggles/svelte`;
---

<div data-install class="flex flex-col h-full bg-white">
  <!-- Framework tabs -->
  <div class="flex border-b border-neutral-300 dark:border-neutral-700">
    <button
      data-fw-btn="react"
      data-active
      class="tab-btn border-r border-neutral-300 dark:border-neutral-700"
      >react</button
    >
    <button
      data-fw-btn="svelte"
      class="tab-btn border-r border-neutral-300 dark:border-neutral-700"
      >svelte</button
    >
  </div>

  <!-- Method tabs -->
  <div
    data-method-row
    class="flex border-b border-neutral-300 dark:border-neutral-700"
  >
    <button
      data-method-btn="shadcn"
      data-active
      class="tab-btn border-r border-neutral-300 dark:border-neutral-700"
      >shadcn/ui</button
    >
    <button
      data-method-btn="manual"
      class="tab-btn border-r border-neutral-300 dark:border-neutral-700"
      >Manual</button
    >
  </div>

  <!-- react + shadcn -->
  <div data-panel="react-shadcn">
    <div class="step">
      <div class="step-header">
        <span class="step-num">1</span>
        <span class="step-label">Run the shadcn CLI</span>
      </div>
      <div class="code-wrapper">
        <button class="copy-btn">Copy</button>
        <Code
          code={shadcnInstall}
          lang="bash"
          themes={{ light: "github-light", dark: "github-dark" }}
        />
      </div>
    </div>
    <div class="step">
      <div class="step-header">
        <span class="step-num">2</span>
        <span class="step-label">Import and use</span>
      </div>
      <div class="code-wrapper">
        <button class="copy-btn">Copy</button>
        <Code
          code={shadcnUsage}
          lang="tsx"
          themes={{ light: "github-light", dark: "github-dark" }}
        />
      </div>
    </div>
  </div>

  <!-- react + manual -->
  <div data-panel="react-manual" hidden>
    <div class="step">
      <div class="step-header">
        <span class="step-num">1</span>
        <span class="step-label">Install dependencies</span>
      </div>
      <div class="code-wrapper">
        <button class="copy-btn">Copy</button>
        <Code
          code={reactInstall}
          lang="bash"
          themes={{ light: "github-light", dark: "github-dark" }}
        />
      </div>
    </div>
    <div class="step">
      <div class="step-header">
        <span class="step-num">2</span>
        <span class="step-label">Copy the component</span>
      </div>
      <div class="code-wrapper">
        <button class="copy-btn">Copy</button>
        <Code
          code={reactSource}
          lang="tsx"
          themes={{ light: "github-light", dark: "github-dark" }}
        />
      </div>
    </div>
  </div>

  <!-- svelte -->
  <div data-panel="svelte" hidden>
    <div class="step">
      <div class="step-header">
        <span class="step-num">1</span>
        <span class="step-label">Install dependencies</span>
      </div>
      <div class="code-wrapper">
        <button class="copy-btn">Copy</button>
        <Code
          code={svelteInstall}
          lang="bash"
          themes={{ light: "github-light", dark: "github-dark" }}
        />
      </div>
    </div>
    <div class="step">
      <div class="step-header">
        <span class="step-num">2</span>
        <span class="step-label">Copy the component</span>
      </div>
      <div class="code-wrapper">
        <button class="copy-btn">Copy</button>
        <Code
          code={svelteSource}
          lang="svelte"
          themes={{ light: "github-light", dark: "github-dark" }}
        />
      </div>
    </div>
  </div>
</div>

<style is:global>
  /* Map .dark body class to shiki dark theme */
  .dark .astro-code {
    background-color: var(--shiki-dark-bg) !important;
    color: var(--shiki-dark) !important;
  }
  .dark .astro-code span {
    color: var(--shiki-dark) !important;
  }
</style>

<style>
  .tab-btn {
    padding: 0.75rem 1.5rem;
    font-size: 0.875rem;
    cursor: pointer;
    transition:
      background-color 0.15s,
      color 0.15s;
    color: var(--color-neutral-500);
  }
  .tab-btn:hover {
    background-color: var(--color-neutral-100);
  }
  .tab-btn[data-active] {
    background-color: var(--color-neutral-100);
    color: var(--color-neutral-900);
  }
  :global(.dark) .tab-btn:hover {
    background-color: var(--color-neutral-800);
  }
  :global(.dark) .tab-btn[data-active] {
    background-color: var(--color-neutral-800);
    color: var(--color-neutral-50);
  }

  [data-method-row] {
    display: flex;
  }
  [data-method-row][hidden] {
    display: none;
  }

  .step {
    border-bottom: 1px solid var(--color-neutral-300);
  }
  .step:last-child {
    border-bottom: none;
  }
  :global(.dark) .step {
    border-bottom-color: var(--color-neutral-700);
  }

  .step-header {
    padding: 0.75rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    border-bottom: 1px solid var(--color-neutral-300);
    background-color: var(--color-neutral-100);
  }
  :global(.dark) .step-header {
    border-bottom-color: var(--color-neutral-700);
    background-color: var(--color-neutral-800);
  }

  .step-num {
    border: 1px solid var(--color-neutral-300);
    width: 1.25rem;
    height: 1.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    color: var(--color-neutral-500);
    flex-shrink: 0;
  }
  :global(.dark) .step-num {
    border-color: var(--color-neutral-600);
    color: var(--color-neutral-400);
  }

  .step-label {
    font-size: 0.75rem;
    color: var(--color-neutral-500);
  }
  :global(.dark) .step-label {
    color: var(--color-neutral-400);
  }

  .code-wrapper {
    position: relative;
  }

  .copy-btn {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    z-index: 10;
    font-size: 0.75rem;
    padding: 0.25rem 0.75rem;
    border: 1px solid var(--color-neutral-300);
    color: var(--color-neutral-500);
    cursor: pointer;
    transition: background-color 0.15s;
    background: transparent;
  }
  .copy-btn:hover {
    background-color: var(--color-neutral-200);
  }
  :global(.dark) .copy-btn {
    border-color: var(--color-neutral-600);
    color: var(--color-neutral-400);
  }
  :global(.dark) .copy-btn:hover {
    background-color: var(--color-neutral-700);
  }

  /* Code block sizing */
  .code-wrapper :global(pre.astro-code) {
    overflow: auto;
    max-height: 18rem;
    padding: 1.5rem;
    font-size: 0.75rem;
    line-height: 1.625;
  }
</style>

<script>
  function initInstallSection(section: Element) {
    let fw = "react";
    let method = "shadcn";

    const fwBtns = section.querySelectorAll<HTMLButtonElement>("[data-fw-btn]");
    const methodBtns =
      section.querySelectorAll<HTMLButtonElement>("[data-method-btn]");
    const methodRow = section.querySelector<HTMLElement>("[data-method-row]");
    const panels = section.querySelectorAll<HTMLElement>("[data-panel]");

    function showPanel() {
      const active = fw === "svelte" ? "svelte" : `${fw}-${method}`;
      panels.forEach((p) => (p.hidden = p.dataset.panel !== active));
      if (methodRow) methodRow.hidden = fw !== "react";
    }

    fwBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        fw = btn.dataset.fwBtn!;
        fwBtns.forEach((b) => delete b.dataset.active);
        btn.dataset.active = "";
        showPanel();
      });
    });

    methodBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        method = btn.dataset.methodBtn!;
        methodBtns.forEach((b) => delete b.dataset.active);
        btn.dataset.active = "";
        showPanel();
      });
    });

    section.querySelectorAll<HTMLButtonElement>(".copy-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        const pre = btn.nextElementSibling as HTMLPreElement;
        if (pre) {
          navigator.clipboard.writeText(pre.textContent ?? "");
          btn.textContent = "Copied!";
          setTimeout(() => (btn.textContent = "Copy"), 2000);
        }
      });
    });
  }

  function init() {
    document.querySelectorAll("[data-install]").forEach(initInstallSection);
  }

  init();
  document.addEventListener("astro:page-load", init);
</script>
