<script>
  const STORAGE_PREFIX = "theme-toggles:install-settings:";
  const PKG_STORAGE_KEY = "theme-toggles:pkg-manager";
  const FRAMEWORKS = ["react", "svelte", "vue"] as const;
  const METHODS_BY_FW: Record<string, string[]> = {
    react: ["shadcn", "npm", "manual"],
    svelte: ["npm", "manual"],
    vue: ["npm", "manual"],
  };
  const PACKAGE_MANAGERS = ["npm", "pnpm", "yarn", "bun"] as const;

  type InstallSettings = {
    fw: string;
    methodByFw: Record<string, string>;
  };

  function defaultSettings(): InstallSettings {
    return {
      fw: "react",
      methodByFw: {
        react: "shadcn",
        svelte: "npm",
        vue: "npm",
      },
    };
  }

  function readPkg(): string {
    try {
      const val = localStorage.getItem(PKG_STORAGE_KEY);
      if (val && PACKAGE_MANAGERS.includes(val as any)) return val;
    } catch {}
    return "npm";
  }

  function writePkg(pkg: string) {
    try {
      localStorage.setItem(PKG_STORAGE_KEY, pkg);
    } catch {}
  }

  function storageKey(section: Element) {
    const slug =
      section instanceof HTMLElement ? section.dataset.toggleSlug : undefined;
    return `${STORAGE_PREFIX}${slug ?? "default"}`;
  }

  function readSettings(section: Element): InstallSettings {
    const settings = defaultSettings();
    try {
      const raw = localStorage.getItem(storageKey(section));
      if (!raw) return settings;

      const parsed = JSON.parse(raw) as Partial<InstallSettings>;
      if (parsed.fw && FRAMEWORKS.includes(parsed.fw as any)) {
        settings.fw = parsed.fw;
      }

      for (const fw of FRAMEWORKS) {
        const method = parsed.methodByFw?.[fw];
        if (method && METHODS_BY_FW[fw].includes(method)) {
          settings.methodByFw[fw] = method;
        }
      }
    } catch {
      return settings;
    }
    return settings;
  }

  function writeSettings(section: Element, settings: InstallSettings) {
    try {
      localStorage.setItem(storageKey(section), JSON.stringify(settings));
    } catch {}
  }

  function initInstallSection(section: Element) {
    if (section instanceof HTMLElement && section.dataset.initialized) return;
    if (section instanceof HTMLElement) section.dataset.initialized = "";

    const settings = readSettings(section);
    let fw = settings.fw;
    const methodByFw = settings.methodByFw;
    let pkg = readPkg();

    const fwBtns = section.querySelectorAll<HTMLButtonElement>("[data-fw-btn]");
    const panels = section.querySelectorAll<HTMLElement>("[data-panel]");
    const reactMethodRow = section.querySelector<HTMLElement>(
      "[data-method-row='react']",
    );
    const svelteMethodRow = section.querySelector<HTMLElement>(
      "[data-method-row='svelte']",
    );
    const vueMethodRow = section.querySelector<HTMLElement>(
      "[data-method-row='vue']",
    );

    function showPackageManager(rowFw: string, pm: string) {
      section
        .querySelectorAll<HTMLElement>(`[data-pkg-code^="${rowFw}-"]`)
        .forEach((el) => {
          el.classList.toggle(
            "hidden",
            el.dataset.pkgCode !== `${rowFw}-${pm}`,
          );
        });
    }

    function updateActiveButtons() {
      fwBtns.forEach((btn) => {
        if (btn.dataset.fwBtn === fw) {
          btn.dataset.active = "";
        } else {
          delete btn.dataset.active;
        }
      });

      [reactMethodRow, svelteMethodRow, vueMethodRow].forEach((row) => {
        if (!row) return;
        const rowFw = row.dataset.methodRow!;
        row
          .querySelectorAll<HTMLButtonElement>("[data-method-btn]")
          .forEach((btn) => {
            if (btn.dataset.methodBtn === methodByFw[rowFw]) {
              btn.dataset.active = "";
            } else {
              delete btn.dataset.active;
            }
          });
      });
    }

    function updatePackageManagers() {
      section
        .querySelectorAll<HTMLSelectElement>("[data-pkg-select]")
        .forEach((select) => {
          const rowFw = select.dataset.pkgSelect!;
          select.value = pkg;
          showPackageManager(rowFw, pkg);
        });
    }

    function persist() {
      writeSettings(section, { fw, methodByFw });
    }

    function showPanel() {
      const active = `${fw}-${methodByFw[fw]}`;
      panels.forEach((p) => (p.hidden = p.dataset.panel !== active));
      if (reactMethodRow) reactMethodRow.hidden = fw !== "react";
      if (svelteMethodRow) svelteMethodRow.hidden = fw !== "svelte";
      if (vueMethodRow) vueMethodRow.hidden = fw !== "vue";
      updateActiveButtons();
    }

    fwBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        fw = btn.dataset.fwBtn!;
        showPanel();
        persist();
      });
    });

    [reactMethodRow, svelteMethodRow, vueMethodRow].forEach((row) => {
      if (!row) return;
      const rowFw = row.dataset.methodRow!;
      row
        .querySelectorAll<HTMLButtonElement>("[data-method-btn]")
        .forEach((btn) => {
          btn.addEventListener("click", () => {
            methodByFw[rowFw] = btn.dataset.methodBtn!;
            showPanel();
            persist();
          });
        });
    });

    section
      .querySelectorAll<HTMLSelectElement>("[data-pkg-select]")
      .forEach((select) => {
        select.addEventListener("change", () => {
          pkg = select.value;
          writePkg(pkg);
          updatePackageManagers();
        });
      });

    section
      .querySelectorAll<HTMLButtonElement>("[data-copy-btn]")
      .forEach((btn) => {
        btn.addEventListener("click", () => {
          const wrapper = btn.nextElementSibling as HTMLElement;
          const pre = wrapper?.matches("pre")
            ? wrapper
            : (wrapper?.querySelector(":not(.hidden) pre") ??
              (btn.nextElementSibling as HTMLPreElement));
          if (pre) {
            navigator.clipboard.writeText(pre.textContent ?? "");
            btn.textContent = "Copied!";
            setTimeout(() => (btn.textContent = "Copy"), 2000);
          }
        });
      });

    showPanel();
    updatePackageManagers();
  }

  function init() {
    document.querySelectorAll("[data-install]").forEach(initInstallSection);
  }

  init();
  document.addEventListener("astro:page-load", init);
</script>
