{
  "name": "@theme-toggles/react",
  "version": "5.0.0",
  "type": "module",
  "license": "MIT",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./dist/index.ts",
    "./styles.css": "./dist/styles.css",
    "./styles/*.css": "./dist/styles/*.css"
  },
  "scripts": {
    "generate": "bun run generate.ts",
    "build": "bun run build.ts",
    "shadcn:build": "shadcn build --output ../../website/public/r",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@theme-toggles/generator": "workspace:*",
    "@theme-toggles/toggles": "workspace:*",
    "@types/react": "^19.2.14"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "dependencies": {
    "shadcn": "^4.6.0"
  }
}
