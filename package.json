{
  "name": "theme-toggles",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "packages/*",
    "website"
  ],
  "type": "module",
  "scripts": {
    "generate": "bun run --filter '@theme-toggles/react' generate && bun run --filter '@theme-toggles/svelte' generate",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "prettier . --write --ignore-unknown",
    "fmt:check": "prettier . --check --ignore-unknown"
  },
  "dependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "clsx": "^2.1.1",
    "liquidjs": "^10.20.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "oxlint": "^1.60.0",
    "prettier": "^3.6.0",
    "prettier-plugin-astro": "^0.14.0",
    "prettier-plugin-svelte": "^3.4.0"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "bun@1.3.12"
}
